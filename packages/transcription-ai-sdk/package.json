{
  "name": "@mcut/transcription-ai-sdk",
  "version": "0.1.0-alpha.1",
  "description": "mcut transcription provider backed by the Vercel AI SDK — use any AI SDK transcription model (OpenAI, Deepgram, Groq, ElevenLabs, ...)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mattppal/mcut.git",
    "directory": "packages/transcription-ai-sdk"
  },
  "peerDependencies": {
    "@mcut/transcription": "workspace:*",
    "ai": ">=5.0.0"
  },
  "devDependencies": {
    "@mcut/transcription": "workspace:*",
    "ai": "^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "Matt Palmer",
  "homepage": "https://github.com/mattppal/mcut/tree/main/packages/transcription-ai-sdk#readme",
  "bugs": {
    "url": "https://github.com/mattppal/mcut/issues"
  },
  "keywords": [
    "mcut",
    "video",
    "video-editing",
    "timeline",
    "typescript",
    "transcription",
    "ai-sdk"
  ]
}
