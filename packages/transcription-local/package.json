{
  "name": "@mcut/transcription-local",
  "version": "0.1.0-alpha.0",
  "description": "On-device mcut transcription provider: Whisper via Transformers.js in a worker — WebGPU-gated, chunked streaming, repetition/VAD guards",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mattppal/mcut.git",
    "directory": "packages/transcription-local"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "peerDependencies": {
    "@mcut/transcription": "workspace:*"
  },
  "devDependencies": {
    "@mcut/transcription": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
