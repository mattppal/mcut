{
  "name": "@mcut/compositor",
  "version": "0.1.0-alpha.0",
  "description": "Canvas2D and WebGPU frame renderer for mcut projects — one compositor for interactive preview and deterministic export",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mattppal/mcut.git",
    "directory": "packages/compositor"
  },
  "dependencies": {
    "@mcut/timeline": "workspace:*",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "Matt Palmer",
  "homepage": "https://github.com/mattppal/mcut/tree/main/packages/compositor#readme",
  "bugs": {
    "url": "https://github.com/mattppal/mcut/issues"
  },
  "keywords": [
    "mcut",
    "video",
    "video-editing",
    "timeline",
    "typescript",
    "canvas",
    "renderer",
    "compositor"
  ]
}
