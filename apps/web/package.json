{
  "name": "mcut-web",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "bun run --cwd ../.. docs:sdk && bun run sync:docs-md && next dev",
    "build": "bun run --cwd ../.. docs:sdk && bun run sync:docs-md && bun run source:docs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "bun run --cwd ../.. docs:sdk && bun run source:docs && tsc --noEmit",
    "source:docs": "fumadocs-mdx",
    "sync:docs-md": "bun run scripts/sync-docs-markdown.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@hugeicons/core-free-icons": "4.2.0",
    "@hugeicons/react": "1.1.6",
    "@types/mdx": "2.0.14",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.3",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "3.6.0",
    "takumi-js": "1.8.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@eslint/compat": "^2.1.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "^16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
