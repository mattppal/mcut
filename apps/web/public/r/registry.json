        },
        "light": {
          "overlay": "oklch(0 0 0)",
          "overlay-foreground": "oklch(1 0 0)"
        }
      },
      "css": {
        "[data-editor]": {
          "--clip-video": "oklch(44.3% 0.11 240.79 / 90%)",
          "--clip-video-foreground": "oklch(97.7% 0.013 236.62)",
          "--clip-audio": "oklch(43.2% 0.095 166.913 / 90%)",
          "--clip-audio-foreground": "oklch(97.9% 0.021 166.113)",
          "--clip-image": "oklch(47.3% 0.137 46.201 / 80%)",
          "--clip-image-foreground": "oklch(98.7% 0.022 95.277)",
          "--clip-text": "oklch(54.1% 0.281 293.009 / 85%)",
          "--clip-text-foreground": "oklch(1 0 0)",
          "--clip-caption": "oklch(58.6% 0.253 17.585 / 85%)",
          "--clip-caption-foreground": "oklch(1 0 0)",
          "--clip-multicam": "oklch(39.8% 0.195 277.366 / 90%)",
          "--clip-multicam-foreground": "oklch(96.2% 0.018 272.314)",
          "--snap-guide": "oklch(74% 0.238 322.16)"
        },
        "@property --scroll-mask-t": {
          "syntax": "\"<number>\"",
          "inherits": "false",
          "initial-value": "0"
        },
        "@property --scroll-mask-b": {
          "syntax": "\"<number>\"",
          "inherits": "false",
          "initial-value": "0"
        },
        "@property --scroll-mask-l": {
          "syntax": "\"<number>\"",
          "inherits": "false",
          "initial-value": "0"
        },
        "@property --scroll-mask-r": {
          "syntax": "\"<number>\"",
          "inherits": "false",
          "initial-value": "0"
        },
        "@keyframes scroll-mask-reveal-t": {
          "from": {
            "--scroll-mask-t": "0"
          },
          "to": {
            "--scroll-mask-t": "1"
          }
        },
        "@keyframes scroll-mask-conceal-b": {
          "from": {
            "--scroll-mask-b": "1"
          },
          "to": {
            "--scroll-mask-b": "0"
          }
        },
        "@keyframes scroll-mask-reveal-l": {
          "from": {
            "--scroll-mask-l": "0"
          },
          "to": {
            "--scroll-mask-l": "1"
          }
        },
        "@keyframes scroll-mask-conceal-r": {
          "from": {
            "--scroll-mask-r": "1"
          },
          "to": {
            "--scroll-mask-r": "0"
          }
        },
        "@utility scroll-mask-y": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to bottom, transparent, black calc(var(--scroll-mask-t) * var(--scroll-mask-size, 1.5rem))), linear-gradient(to top, transparent, black calc(var(--scroll-mask-b) * var(--scroll-mask-size, 1.5rem)))",
              "mask-composite": "intersect",
              "animation": "scroll-mask-reveal-t linear both, scroll-mask-conceal-b linear both",
              "animation-timeline": "scroll(self block)",
              "animation-range": "0px calc(var(--scroll-mask-size, 1.5rem) * 2), calc(100% - var(--scroll-mask-size, 1.5rem) * 2) 100%"
            }
          }
        },
        "@utility scroll-mask-x": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to right, transparent, black calc(var(--scroll-mask-l) * var(--scroll-mask-size, 1.5rem))), linear-gradient(to left, transparent, black calc(var(--scroll-mask-r) * var(--scroll-mask-size, 1.5rem)))",
              "mask-composite": "intersect",
              "animation": "scroll-mask-reveal-l linear both, scroll-mask-conceal-r linear both",
              "animation-timeline": "scroll(self inline)",
              "animation-range": "0px calc(var(--scroll-mask-size, 1.5rem) * 2), calc(100% - var(--scroll-mask-size, 1.5rem) * 2) 100%"
            }
          }
        },
        "@utility scroll-mask-t": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to bottom, transparent, black calc(var(--scroll-mask-t) * var(--scroll-mask-size, 1.5rem)))",
              "animation": "scroll-mask-reveal-t linear both",
              "animation-timeline": "scroll(self block)",
              "animation-range": "0px calc(var(--scroll-mask-size, 1.5rem) * 2)"
            }
          }
        },
        "@utility scroll-mask-b": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to top, transparent, black calc(var(--scroll-mask-b) * var(--scroll-mask-size, 1.5rem)))",
              "animation": "scroll-mask-conceal-b linear both",
              "animation-timeline": "scroll(self block)",
              "animation-range": "calc(100% - var(--scroll-mask-size, 1.5rem) * 2) 100%"
            }
          }
        },
        "@utility scroll-mask-l": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to right, transparent, black calc(var(--scroll-mask-l) * var(--scroll-mask-size, 1.5rem)))",
              "animation": "scroll-mask-reveal-l linear both",
              "animation-timeline": "scroll(self inline)",
              "animation-range": "0px calc(var(--scroll-mask-size, 1.5rem) * 2)"
            }
          }
        },
        "@utility scroll-mask-r": {
          "@supports (animation-timeline: scroll())": {
            "&, & [data-slot=\"scroll-area-viewport\"]": {
              "mask-image": "linear-gradient(to left, transparent, black calc(var(--scroll-mask-r) * var(--scroll-mask-size, 1.5rem)))",
              "animation": "scroll-mask-conceal-r linear both",
              "animation-timeline": "scroll(self inline)",
              "animation-range": "calc(100% - var(--scroll-mask-size, 1.5rem) * 2) 100%"
            }
          }
        },
